{
  "name": "autobazar123",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:prod-rate-limit-env && next build",
    "start": "next start",
    "lint": "eslint && npm run check:text-encoding && npm run check:sk-diacritics && npm run check:theme-guard",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "analyze": "cross-env ANALYZE=true next build",
    "audit:webapp": "npx playwright test tests/webapp-audit.ts",
    "audit:webapp:webpack": "cross-env PLAYWRIGHT_WEB_SERVER_COMMAND=\"next dev --webpack\" npx playwright test tests/webapp-audit.ts",
    "check:performance-budgets": "node scripts/performance-budget-gate.mjs",
    "test:e2e": "npx playwright test tests/e2e.test.ts",
    "test:release-gauntlet": "npx playwright test tests/release-gauntlet.test.ts",
    "test:smoke": "npx tsx tests/smoke-test.ts",
    "test:links": "npx playwright test tests/link-and-mobile-test.ts",
    "test:web-interface:core": "npx playwright test tests/web-interface-guidelines.test.ts",
    "test:web-interface:sitewide": "npx playwright test tests/web-interface-sitewide.test.ts",
    "test:web-interface": "npm run test:web-interface:core && npm run test:web-interface:sitewide",
    "test:a11y": "npx playwright test tests/accessibility-gate.test.ts tests/reflow-zoom.test.ts",
    "test:keyboard": "npx playwright test tests/keyboard-navigation.test.ts",
    "test:sr-proxy": "npx playwright test tests/screen-reader-proxy.test.ts",
    "test:mobile-matrix": "npx playwright test tests/accessibility-gate.test.ts tests/reflow-zoom.test.ts --project=mobile-pixel-7 --project=mobile-iphone-13-landscape",
    "test:ui-qa": "npm run test:web-interface && npx vitest run src/components/AuthModal.password-strength.test.tsx src/components/AuthModal.email-flow.test.tsx",
    "docs:vendor:sync": "node scripts/vendor-docs-sync.mjs",
    "links:ingest": "node scripts/links-ingest.mjs",
    "test:links-ingest": "node --test scripts/links-ingest.test.mjs",
    "test:security:policy": "node scripts/security-release-gate.mjs --skip-commands",
    "test:security:release-gate": "node scripts/security-release-gate.mjs",
    "test:security-gate-script": "node --test scripts/security-release-gate.test.mjs",
    "check:framework-patch-posture": "node scripts/framework-patch-posture.mjs",
    "test:framework-patch-posture-script": "node --test scripts/framework-patch-posture.test.mjs",
    "check:github-actions-oidc-posture": "node scripts/github-actions-oidc-posture.mjs",
    "test:github-actions-oidc-posture-script": "node --test scripts/github-actions-oidc-posture.test.mjs",
    "test:performance-budget-gate-script": "node --test scripts/performance-budget-gate.test.mjs",
    "check:prod-rate-limit-env": "node scripts/check-prod-rate-limit-env.mjs",
    "check:theme-guard": "node scripts/theme-guard.mjs",
    "test:prod-rate-limit-env-guard": "node --test scripts/check-prod-rate-limit-env.test.mjs",
    "check:text-encoding": "node scripts/text-encoding-guard.mjs",
    "check:current-chat-model": "node scripts/current-chat-model.mjs",
    "test:model-check": "node scripts/model-check.mjs",
    "test:current-chat-model-script": "node --test scripts/current-chat-model.test.mjs",
    "test:codex-cli-check": "node scripts/codex-cli-check.mjs",
    "test:agent-browser": "node scripts/agent-browser-smoke.mjs",
    "test:seo-taxonomy": "vitest run src/lib/seo/programmatic-taxonomy.test.ts src/proxy.test.ts src/app/sitemap.test.ts",
    "check:sk-diacritics": "node scripts/slovak-diacritics-check.mjs",
    "check:sk-diacritics:write": "node scripts/slovak-diacritics-check.mjs --write",
    "test:sk-diacritics-script": "node --test scripts/slovak-diacritics-check.test.mjs",
    "bench:agent:list": "node scripts/agent-benchmark.mjs --list",
    "bench:agent:init": "node scripts/agent-benchmark.mjs --init-report output/benchmarks/agent-report.template.json",
    "bench:agent:score": "node scripts/agent-benchmark.mjs --score output/benchmarks/agent-report.json",
    "test:agent-benchmark-script": "node --test scripts/agent-benchmark.test.mjs",
    "test:agent-contract": "node scripts/agent-contract-check.mjs",
    "test:workflow-check": "node scripts/workflow-check.mjs",
    "test:agent-contract-script": "node --test scripts/agent-contract-check.test.mjs",
    "test:ui-quality-gate": "node scripts/ui-quality-gate.mjs",
    "test:ui-quality-gate-script": "node --test scripts/ui-quality-gate.test.mjs",
    "test:skill-graph": "node scripts/skill-graph-check.mjs",
    "test:skill-graph-script": "node --test scripts/skill-graph-check.test.mjs",
    "easy:quick": "node scripts/easy-ops.mjs quick",
    "easy:full": "node scripts/easy-ops.mjs full",
    "easy:test": "node --test scripts/easy-ops.test.mjs",
    "ui:shadcn": "shadcn",
    "ui:shadcn:info": "shadcn info",
    "ui:shadcn:docs": "shadcn docs",
    "ui:shadcn:add": "shadcn add",
    "ui:shadcn:add:dry-run": "shadcn add --dry-run",
    "ui:shadcn:add:diff": "shadcn add --diff",
    "ui:shadcn:init:preset": "shadcn init --preset",
    "ui:shadcn:init:base": "shadcn init --base",
    "ui:shadcn:mcp:init:codex": "shadcn mcp init --client codex",
    "skills:list": "skills list",
    "skills:restore": "skills experimental_install -y"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
