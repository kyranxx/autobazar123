          {t("brand.subtitle")}
        </p>
      </div>

      <div className="relative z-10 space-y-3">
        <div className="flex items-center gap-3">
          <div className="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: "rgba(120, 240, 176, 0.18)" }}>
