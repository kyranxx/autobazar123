{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "git": {
        "deploymentEnabled": {
            "*": false,
            "master": true
        }
    },
    "regions": [
        "fra1"
    ],
    "crons": [
        {
            "path": "/api/cron/expire-ads",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/cleanup-sold",
            "schedule": "0 18 * * *"
        }
    ]
}
