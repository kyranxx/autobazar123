# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# test scripts (track curated gate/ops scripts only)
/scripts/*
!/scripts/agent-benchmark.mjs
!/scripts/agent-benchmark.test.mjs
!/scripts/agent-contract-check.mjs
!/scripts/agent-contract-check.test.mjs
!/scripts/links-ingest.mjs
!/scripts/links-ingest.test.mjs
!/scripts/security-release-gate.mjs
!/scripts/security-release-gate.test.mjs
!/scripts/skill-graph-check.mjs
!/scripts/skill-graph-check.test.mjs
!/scripts/ui-quality-gate.mjs
!/scripts/ui-quality-gate.test.mjs
!/scripts/easy-ops.mjs
!/scripts/easy-ops.test.mjs
lighthouse-report.json

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*_output.txt
*_output_*.txt
.codex_tmp/
eslint-output.json
eslint-report.txt
test-results.json
tsc-errors.txt
public/diagnostic.html
.agent/active_agents/

# local artifacts
/output/
output_*.png
mobile_issue*.png

# playwright-cli (local debug artifacts)
.playwright-cli/
playwright-cli.json
