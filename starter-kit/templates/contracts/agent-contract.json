{
  "version": 1,
  "repository": "__REPOSITORY__",
  "description": "Starter agent contract for __PROJECT_NAME__. Defines risk tiers, required checks, and docs sync rules.",
  "riskTierRules": {
    "high": [
      "src/app/api/**",
      "src/lib/security/**",
      ".github/workflows/**"
    ],
    "medium": [
      "src/**",
      "scripts/**",
      "docs/**"
    ],
    "low": [
      "**"
    ]
  },
  "requiredChecksByTier": {
    "high": [
      "test:security:release-gate",
      "test:workflow-check",
      "test:agent-contract"
    ],
    "medium": [
      "test:workflow-check",
      "test:agent-contract",
      "test:skill-graph"
    ],
    "low": [
      "test:workflow-check",
      "test:agent-contract"
    ]
  },
  "docsSyncRules": [
    {
      "paths": [
        "scripts/**",
        ".github/workflows/**",
        "contracts/**",
        "config/**"
      ],
      "requiredDocs": [
        "docs/easy-mode.md",
        "docs/future-llm-prompt-template.md",
        "docs/links-ingestion.md"
      ]
    }
  ],
  "evidenceRequirements": {
    "securityChanges": [
      "test:security:release-gate"
    ],
    "processChanges": [
      "test:workflow-check",
      "test:agent-contract"
    ]
  },
  "reviewPolicy": {
    "requireCurrentHeadEvidence": true,
    "rejectStaleReviewState": true,
    "allowAutoResolveBotOnlyThreads": true
  }
}
