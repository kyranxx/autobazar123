{
  "version": 1,
  "repository": "kyranxx/autobazar123",
  "description": "Autobazar123 agent merge contract. Defines risk tiers, required checks, and documentation drift guards.",
  "riskTierRules": {
    "high": [
      "src/app/api/**",
      "src/lib/security/**",
      "src/proxy.ts",
      "supabase/migrations/**"
    ],
    "medium": [
      "src/app/**",
      "src/components/**",
      "src/lib/**"
    ],
    "tooling": [
      ".github/workflows/**",
      ".github/pull_request_template.md",
      "contracts/**",
      "scripts/**",
      "skills-graph/**",
      "docs/codex-workflow-checklist.md"
    ],
    "low": [
      "**"
    ]
  },
  "requiredChecksByTier": {
    "high": [
      "test:security:release-gate",
      "test:ui-quality-gate"
    ],
    "medium": [
      "test:ui-quality-gate"
    ],
    "tooling": [
      "test:workflow-check",
      "test:agent-contract",
      "test:skill-graph"
    ],
    "low": [
      "test:unit"
    ]
  },
  "docsSyncRules": [
    {
      "paths": [
        "scripts/**",
        ".github/workflows/**",
        "contracts/**"
      ],
      "requiredDocs": [
        "docs/PROJECT_PLAYBOOK.md",
        "docs/codex-workflow-checklist.md"
      ]
    }
  ],
  "evidenceRequirements": {
    "uiChanges": [
      "test:web-interface",
      "test:ui-quality-gate"
    ],
    "securityChanges": [
      "test:security:release-gate"
    ],
    "analyticsChanges": [
      "test:unit"
    ]
  },
  "reviewPolicy": {
    "requireCurrentHeadEvidence": true,
    "rejectStaleReviewState": true,
    "allowAutoResolveBotOnlyThreads": true
  }
}
