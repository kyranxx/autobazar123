{
  "version": 1,
  "requiredFiles": [
    "src/proxy.ts",
    "src/lib/security/csp.ts",
    "src/lib/ratelimit.ts",
    "src/app/api/account/password/route.ts",
    "src/app/api/account/delete/route.ts",
    "src/app/api/flags/route.ts",
    "src/app/api/monitoring/quality-gates/route.ts",
    "src/app/api/monitoring/quality-gates/route-internals.ts",
    "src/lib/security/github-actions-oidc.ts",
    "src/app/api/images/upload-url/route.ts",
    "src/app/api/algolia/sync/route.ts",
    "src/app/api/cron/cleanup-sold/route.ts",
    "scripts/framework-patch-posture.mjs",
    "scripts/framework-patch-posture.test.mjs",
    "scripts/github-actions-oidc-posture.mjs",
    "scripts/github-actions-oidc-posture.test.mjs",
    ".github/workflows/accessibility-quality-gate.yml",
    ".github/workflows/performance-budget-gate.yml",
    "supabase/migrations/20260218_security_review_hardening.sql",
    "docs/PROJECT_PLAYBOOK.md",
    "docs/security-top-10-defaults.md"
  ],
  "requiredMarkers": [
    {
      "file": "src/proxy.ts",
      "markers": [
        "Content-Security-Policy",
        "checkRateLimit",
        "isValidMaintenanceBypassToken",
        "X-Request-ID"
      ]
    },
    {
      "file": "src/app/api/account/password/route.ts",
      "markers": [
        "supabase.auth.getUser",
        "Unauthorized"
      ]
    },
    {
      "file": "src/app/api/account/delete/route.ts",
      "markers": [
        "supabase.auth.getUser",
        "z.literal(\"DELETE\")"
      ]
    },
    {
      "file": "src/app/api/flags/route.ts",
      "markers": [
        "CACHE_HEADERS.PRIVATE",
        "\"Cache-Control\": privateCacheControl"
      ]
    },
    {
      "file": "src/app/api/monitoring/quality-gates/route.ts",
      "markers": [
        "authSource"
      ]
    },
    {
      "file": "src/app/api/monitoring/quality-gates/route-internals.ts",
      "markers": [
        "verifyGitHubActionsOidcToken",
        "github_oidc"
      ]
    },
    {
      "file": "src/lib/security/github-actions-oidc.ts",
      "markers": [
        "QUALITY_GATE_ALERT_ALLOWED_REPOSITORIES",
        "token.actions.githubusercontent.com",
        "DEFAULT_QUALITY_GATE_OIDC_AUDIENCE"
      ]
    },
    {
      "file": ".github/workflows/accessibility-quality-gate.yml",
      "markers": [
        "id-token: write",
        "ACTIONS_ID_TOKEN_REQUEST_URL",
        "Authorization: Bearer $QUALITY_ALERT_OIDC_TOKEN"
      ]
    },
    {
      "file": ".github/workflows/performance-budget-gate.yml",
      "markers": [
        "id-token: write",
        "ACTIONS_ID_TOKEN_REQUEST_URL",
        "Authorization: Bearer $QUALITY_ALERT_OIDC_TOKEN"
      ]
    },
    {
      "file": "src/app/api/images/upload-url/route.ts",
      "markers": [
        "Unauthorized - Please login to upload images",
        "Cloudflare Images validates uploaded bytes during direct upload."
      ]
    },
    {
      "file": "src/app/api/algolia/sync/route.ts",
      "markers": [
        "ALGOLIA_SYNC_SECRET",
        "Unauthorized"
      ]
    },
    {
      "file": "src/app/api/cron/cleanup-sold/route.ts",
      "markers": [
        "CRON_SECRET",
        "Unauthorized"
      ]
    }
  ],
  "requiredDocTokens": [
    {
      "file": "docs/PROJECT_PLAYBOOK.md",
      "tokens": [
        "Security Baseline",
        "test:security:release-gate",
        "check:framework-patch-posture",
        "GitHub Actions OIDC"
      ]
    },
    {
      "file": "docs/security-top-10-defaults.md",
      "tokens": [
        "Security Top-10 Defaults",
        "test:security:release-gate",
        "check:framework-patch-posture",
        "GitHub Actions OIDC"
      ]
    }
  ],
  "requiredPackageScripts": [
    "check:framework-patch-posture",
    "test:framework-patch-posture-script",
    "check:github-actions-oidc-posture",
    "test:github-actions-oidc-posture-script",
    "check:prod-rate-limit-env",
    "test:prod-rate-limit-env-guard",
    "test:security:release-gate"
  ],
  "frameworkPatchPosture": {
    "enforceReactDomVersionParity": true,
    "packages": [
      {
        "name": "next",
        "maxLagDays": 7
      },
      {
        "name": "react",
        "maxLagDays": 14
      },
      {
        "name": "react-dom",
        "maxLagDays": 14
      }
    ]
  },
  "commands": [
    "npm run check:framework-patch-posture",
    "npm run check:github-actions-oidc-posture",
    "npm run test:github-actions-oidc-posture-script",
    "npm run test:prod-rate-limit-env-guard",
    "npm run check:prod-rate-limit-env",
    "npm run typecheck",
    "npx vitest run src/lib/security/csp.test.ts src/lib/auth/oauth-redirect.test.ts src/utils/upload.test.ts",
    "npm run test:links-ingest"
  ]
}
